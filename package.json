{
  "name": "health-signal-dashboard",
  "version": "3.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "typecheck": "pnpm run typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typegen": "node ./scripts/prepare-typegen.mjs && next typegen",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "audit:high": "pnpm audit --audit-level high",
    "docs:lint": "markdownlint-cli2 README.md docs/**/*.md",
    "docs:mermaid": "node ./scripts/check-mermaid.mjs",
    "docs:check": "pnpm run docs:lint && pnpm run docs:mermaid"
  },
  "dependencies": {
    "@mantine/charts": "^8.3.17",
    "@mantine/core": "^8.3.17",
    "@mantine/dates": "^8.3.17",
    "@mantine/hooks": "^8.3.17",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.8.7",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "ignoredOptionalDependencies": [
      "jsdom"
    ]
  }
}
